{
  "expo": {
    "name": "Career AI",
    "slug": "career-ai",
    "version": "1.0.0",
    "scheme": "com.app.mobile",
    "orientation": "portrait",
    "icon": "./assets/favicon/web-app-manifest-512x512.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.app.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.app.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#00B4D8",
        "foregroundImage": "./assets/favicon/web-app-manifest-512x512.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon/favicon.ico"
    },
    "extra": {
      "googleAndroidClientId": "",
      "googleIosClientId": "",
      "googleWebClientId": ""
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/favicon/web-app-manifest-512x512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00B4D8"
        }
      ],
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1007119854456-ansh885oem7j8vhobqqdu09dg7r6hjub"
        }
      ]
    ]
  }
}
