# Public API URL — use your deployed backend (works on any network)
# After Render deploy: https://your-service.onrender.com/api/v1
# Local same Wi‑Fi only: http://YOUR_PC_IP:5000/api/v1
# Android emulator only: http://10.0.2.2:5000/api/v1
EXPO_PUBLIC_API_URL=https://your-service.onrender.com/api/v1

# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
